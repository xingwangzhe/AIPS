# ============================================================
# AIPS 后端环境变量模板
# LangChain4j + DeepSeek V4
# 复制为 .env，填入真实值
# ============================================================

# 数据库 (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/aips
DB_USERNAME=aips
DB_PASSWORD=aips123

# JWT 密钥（openssl rand -base64 64 生成）
JWT_SECRET=替换为随机密钥
JWT_EXPIRATION_MS=7200000

# LangChain4j / DeepSeek API
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-v4-flash
