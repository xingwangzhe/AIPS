# ============================================================
# AIPS 后端环境变量模板
# 复制为 .env 后填入真实值（.env 不会被 git 追踪）
# ============================================================

# 数据库 (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/aips
DB_USERNAME=aips
DB_PASSWORD=aips123

# JWT
JWT_SECRET=替换为随机生成的至少256位密钥
JWT_EXPIRATION_MS=7200000

# Spring AI — DeepSeek（OpenAI 兼容协议）
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-v4-flash
